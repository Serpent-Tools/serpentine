base = Image("quay.io/toolbx-images/alpine-toolbox:3.21@sha256:ff9f4d34ce354d6be4c8fc551ebb1bb57c5941df4b42c970b9852f3744fb6bf0")
    > WorkingDir("/app")
    > Exec("touch hello.txt")
    > Exec("mkdir foo")
    > Exec("touch foo/hello.txt");

hello = base > Export("hello.txt");
foo = base > Export("foo");

check_hello = Image("quay.io/toolbx-images/alpine-toolbox:3.21@sha256:ff9f4d34ce354d6be4c8fc551ebb1bb57c5941df4b42c970b9852f3744fb6bf0")
    > With(hello, "nice.txt")
    > Exec("cat nice.txt");

check_foo = Image("quay.io/toolbx-images/alpine-toolbox:3.21@sha256:ff9f4d34ce354d6be4c8fc551ebb1bb57c5941df4b42c970b9852f3744fb6bf0")
    > With(foo, "bar")
    > Exec("cat bar/hello.txt");

export DEFAULT = !(check_hello, check_foo) Noop(0);
