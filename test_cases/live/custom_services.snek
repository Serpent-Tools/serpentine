base = Image("quay.io/toolbx-images/alpine-toolbox:3.21@sha256:ff9f4d34ce354d6be4c8fc551ebb1bb57c5941df4b42c970b9852f3744fb6bf0") > Exec("apk add curl");

python_server = base
    > Exec("apk add python3")
    > ToService("python3 -m http.server 8000")
    > HealthCheck("curl -f http://localhost:8000", 5);

ping_python = base 
    > WithService(python_server, "server")
    > Exec("curl -f http://server:8000");

nested_service = base
    > Exec("apk add caddy")
    > WithService(python_server, "python")
    > ToService("caddy reverse-proxy --from :8000 --to python:8000")
    > HealthCheck("curl -f http://localhost:8000", 5);

test_nested = base
    > WithService(nested_service, "nested")
    > Exec("curl -f http://nested:8000")
    > Exec("! curl -f http://python:8000");

export DEFAULT = !(ping_python, test_nested) Noop(0);
